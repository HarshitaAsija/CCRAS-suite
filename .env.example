# Backend
DEBUG=1
DATABASE_URL=postgresql://postgres:postgres@db:5432/brahma
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
OLLAMA_HOST=http://ollama:11434

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Brahma

# AI
OLLAMA_MODEL=llama2
EMBEDDING_MODEL=BioBERT

# Security (example)
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# copy this to .env and fill in if your DB differs from default
CCRAS_DB_HOST=100.101.210.91
CCRAS_DB_PORT=5432
CCRAS_DB_NAME=ccras_db
CCRAS_DB_USER=readonly
CCRAS_DB_PASSWORD=Read1234
